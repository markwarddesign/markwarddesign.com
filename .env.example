# ─── Client-side (Vite, prefixed VITE_) ─────────────────────────────────────
# Cloudflare Turnstile *site* key (public). The widget loads with this key.
VITE_TURNSTILE_SITE_KEY=

# ─── Server-side (Cloudflare Pages env vars — set in dashboard, not here) ────
# These are the names the contact function reads. Do NOT commit real values.
#
#   RESEND_API_KEY         re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   TURNSTILE_SECRET_KEY   0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxx
#   CONTACT_TO             mark@markward.dev                 (optional override)
#   CONTACT_FROM           Mark Ward <noreply@markward.dev>  (optional override)
#
# Optional KV binding for rate limiting:
#   CONTACT_RATE_LIMIT     bound to a Workers KV namespace
